@@ -0,0 +1,61 @@
+package org.jellyfin.androidtv.theme
+
+import android.animation.ValueAnimator
+import android.content.Context
+import android.graphics.BlurMaskFilter
+import android.graphics.Canvas
+import android.graphics.Color
+import android.graphics.Paint
+import android.util.AttributeSet
+import android.view.View
+
+/**
+ * Spotlight overlay - amber glow that follows focus for Luxia Temple theme.
+ * 150dp radius, 30% opacity, smooth interpolation (200ms).
+ */
+class SpotlightOverlayView @JvmOverloads constructor(
+    context: Context,
+    attrs: AttributeSet? = null
+) : View(context, attrs) {
+
+    private val spotlightPaint = Paint(Paint.ANTI_ALIAS_FLAG).apply {
+        color = Color.parseColor("#66FFB347") // 40% amber
+        maskFilter = BlurMaskFilter(150f, BlurMaskFilter.Blur.NORMAL)
+    }
+
+    private var spotlightX = 0f
+    private var spotlightY = 0f
+    private var targetX = 0f
+    private var targetY = 0f
+    private var currentAnimator: ValueAnimator? = null
+
+    fun moveTo(x: Float, y: Float) {
+        targetX = x
+        targetY = y
+
+        // Cancel existing animation
+        currentAnimator?.cancel()
+
+        // Animate to target position
+        currentAnimator = ValueAnimator.ofFloat(0f, 1f).apply {
+            duration = 200
+            addUpdateListener { animator ->
+                val fraction = animator.animatedFraction
+                spotlightX = spotlightX + (targetX - spotlightX) * fraction
+                spotlightY = spotlightY + (targetY - spotlightY) * fraction
+                invalidate()
+            }
+            start()
+        }
+    }
+
+    override fun onDraw(canvas: Canvas) {
+        super.onDraw(canvas)
+        canvas.drawCircle(spotlightX, spotlightY, 200f, spotlightPaint)
+    }
+
+    override fun onDetachedFromWindow() {
+        super.onDetachedFromWindow()
+        currentAnimator?.cancel()
+    }
+}
