@@ -0,0 +1,81 @@
+package org.jellyfin.androidtv.theme
+
+import android.content.Context
+import android.graphics.BlurMaskFilter
+import android.graphics.Canvas
+import android.graphics.Color
+import android.graphics.Paint
+import android.util.AttributeSet
+import android.view.Choreographer
+import android.view.View
+import kotlin.math.max
+import kotlin.math.min
+
+/**
+ * Flame overlay - rising embers for Luxia Temple theme.
+ * Canvas-based, 30fps cap, 12-15 particles max for Firestick performance.
+ * Only visible on home screen - hidden during playback.
+ */
+class FlameOverlayView @JvmOverloads constructor(
+    context: Context,
+    attrs: AttributeSet? = null
+) : View(context, attrs) {
+
+    private val paint = Paint(Paint.ANTI_ALIAS_FLAG).apply {
+        style = Paint.Style.FILL
+    }
+
+    private val particles = mutableListOf<FlameParticle>()
+
+    init {
+        // Initialize 12 particles (performance-safe for Firestick)
+        repeat(12) {
+            particles.add(FlameParticle())
+        }
+
+        // Start animation loop at 30fps
+        Choreographer.getInstance().postFrameCallback { frame ->
+            updateParticles()
+            invalidate()
+            if (visibility == View.VISIBLE) {
+                Choreographer.getInstance().postFrameCallback { frame }
+            }
+        }
+    }
+
+    private fun updateParticles() {
+        particles.forEach { it.update() }
+    }
+
+    override fun onDraw(canvas: Canvas) {
+        super.onDraw(canvas)
+        particles.forEach { it.draw(canvas, paint) }
+    }
+
+    private data class FlameParticle(
+        var x: Float = (0..1000).random().toFloat(),
+        var y: Float = (800..1200).random().toFloat(),
+        var size: Float = (4..8).random().toFloat(),
+        var speed: Float = (50..100).random().toFloat(),
+        var alpha: Float = 1.0f
+    ) {
+        fun update() {
+            y -= speed / 60f // Rise
+            alpha -= 0.002f // Fade
+            if (alpha <= 0 || y < 0) {
+                // Respawn at bottom
+                y = 1200f
+                alpha = 1.0f
+                x = (0..1000).random().toFloat()
+            }
+        }
+
+        fun draw(canvas: Canvas, paint: Paint) {
+            // Amber to orange gradient effect via alpha
+            val amber = Color.parseColor("#FFFFB347")
+            paint.color = amber
+            paint.alpha = (alpha * 255).toInt()
+            canvas.drawCircle(x, y, size, paint)
+        }
+    }
+}
diff --git a/app/src/main/java/org/jellyfin/androidtv/theme/LuxiaThemeManager.kt b/app/src/main/java/org/jellyfin/androidtv/theme/LuxiaThemeManager.kt
