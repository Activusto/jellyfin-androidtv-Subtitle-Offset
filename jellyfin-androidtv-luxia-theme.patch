@@ -0,0 +1,107 @@
+package org.jellyfin.androidtv.theme
+
+import android.app.Activity
+import android.content.Context
+import android.view.View
+import android.view.ViewGroup
+import android.widget.FrameLayout
+import org.jellyfin.androidtv.preference.UserPreferences
+
+/**
+ * Luxia Temple Theme Manager - applies and removes the Luxia theme.
+ * Handles flame overlay and spotlight overlay lifecycle.
+ */
+object LuxiaThemeManager {
+
+    private var flameOverlay: FlameOverlayView? = null
+    private var spotlightOverlay: SpotlightOverlayView? = null
+
+    fun apply(context: Context, enabled: Boolean) {
+        if (enabled) {
+            // Apply Luxia theme
+            context.setTheme(org.jellyfin.androidtv.R.style.LuxiaTheme)
+        } else {
+            // Revert to stock
+            context.setTheme(org.jellyfin.androidtv.R.style.Theme_Jellyfin)
+        }
+    }
+
+    /**
+     * Add flame overlay to home screen.
+     * Call once during home screen setup.
+     */
+    fun enableFlameOverlay(parent: ViewGroup) {
+        // Check if already added
+        if (flameOverlay != null) return
+
+        flameOverlay = FlameOverlayView(parent.context).apply {
+            id = View.generateViewId()
+            layoutParams = FrameLayout.LayoutParams(
+                FrameLayout.LayoutParams.MATCH_PARENT,
+                FrameLayout.LayoutParams.MATCH_PARENT
+            )
+            isClickable = false
+            isFocusable = false
+        }
+
+        parent.addView(flameOverlay)
+    }
+
+    /**
+     * Remove flame overlay.
+     * Call when leaving home screen or disabling theme.
+     */
+    fun disableFlameOverlay(parent: ViewGroup) {
+        flameOverlay?.let {
+            parent.removeView(it)
+            flameOverlay = null
+        }
+    }
+
+    /**
+     * Add spotlight overlay to home screen.
+     * Call once during home screen setup.
+     */
+    fun enableSpotlight(parent: ViewGroup): SpotlightOverlayView {
+        // Check if already added
+        spotlightOverlay?.let { return it }
+
+        spotlightOverlay = SpotlightOverlayView(parent.context).apply {
+            id = View.generateViewId()
+            layoutParams = FrameLayout.LayoutParams(
+                FrameLayout.LayoutParams.MATCH_PARENT,
+                FrameLayout.LayoutParams.MATCH_PARENT
+            )
+            isClickable = false
+            isFocusable = false
+        }
+
+        parent.addView(spotlightOverlay)
+        return spotlightOverlay!!
+    }
+
+    /**
+     * Remove spotlight overlay.
+     * Call when leaving home screen or disabling theme.
+     */
+    fun disableSpotlight(parent: ViewGroup) {
+        spotlightOverlay?.let {
+            parent.removeView(it)
+            spotlightOverlay = null
+        }
+    }
+
+    /**
+     * Hide flames during playback (no distraction).
+     */
+    fun hideFlames() {
+        flameOverlay?.visibility = View.GONE
+    }
+
+    /**
+     * Show flames (home screen).
+     */
+    fun showFlames() {
+        flameOverlay?.visibility = View.VISIBLE
+    }
+}
